# Backend
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Auth
JWT_SECRET=change-me-local-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-admin-password

# GigaChat
GIGA_API_KEY=put-your-gigachat-authorization-key-here
GIGA_MODEL=GigaChat-2
GIGA_SCOPE=GIGACHAT_API_PERS
GIGA_VERIFY_SSL_CERTS=true
GIGA_TIMEOUT=30

# Data
FLYFORECAST_DATASET_PATH=/app/data/processed/dataset_daily_flights.csv
PREDICTION_LOG_PATH=/app/data/interim/prediction_logs.jsonl
EXPLANATION_CACHE_PATH=/app/data/interim/explanation_cache.sqlite
POSTGRES_DB=flyforecast
POSTGRES_USER=flyforecast
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://flyforecast:change-me-postgres-password@db:5432/flyforecast
USER_STORE_PATH=/app/data/interim/users.json
FEEDBACK_LOG_PATH=/app/data/interim/feedback_logs.jsonl
CONSENT_LOG_PATH=/app/data/interim/consent_logs.jsonl
FORECAST_MONITOR_DB_PATH=/app/data/interim/evaluation/forecast_monitor.sqlite
WEATHER_FORECAST_CACHE_PATH=/app/data/interim/weather_forecast_cache.sqlite
WEATHER_CACHE_FRESH_HOURS=1
WEATHER_CACHE_STALE_HOURS=72
OPEN_METEO_FAILURE_COOLDOWN_MINUTES=30
WEATHER_FORECAST_WINDOW_START_HOUR=8
WEATHER_FORECAST_WINDOW_END_HOUR=20
WEATHER_FLIGHT_WINDOW_MIN_HOURS=3
WEATHER_FLIGHT_WINDOW_MIN_VISIBILITY=5000
WEATHER_FLIGHT_WINDOW_MAX_CLOUD_LOW=80
WEATHER_FLIGHT_WINDOW_MAX_WIND_GUSTS=45
WEATHER_FLIGHT_WINDOW_MAX_PRECIPITATION=2.5
MET_NO_FALLBACK_ENABLED=true
MET_NO_USER_AGENT=flyforecast.ru/0.1(+https://flyforecast.ru;admin@example.com)
FLIGHT_STATUS_DATASET_PATH=/app/data/raw/flight_status/kunashir_flight_status_hourly.csv
FLIGHT_STATUS_ERRORS_PATH=/app/data/raw/flight_status/collection_errors.csv
BACKGROUND_SERVICE_STALE_HOURS=26

# Mendeleyevo / Kunashir approximate coordinates, можно потом уточнить
AIRPORT_LATITUDE=43.958
AIRPORT_LONGITUDE=145.683
AIRPORT_TIMEZONE=Asia/Sakhalin
