# Backend
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Test auth
TEST_USERNAME=demo
TEST_PASSWORD=demo123
JWT_SECRET=change-me-local-secret

# OpenAI
OPENAI_API_KEY=put-your-openai-api-key-here
