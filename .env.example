# Backend
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Test auth
TEST_USERNAME=demo
TEST_PASSWORD=demo123
JWT_SECRET=change-me-local-secret

# GigaChat
GIGA_API_KEY=put-your-gigachat-authorization-key-here
GIGA_MODEL=GigaChat-2
GIGA_SCOPE=GIGACHAT_API_PERS
GIGA_VERIFY_SSL_CERTS=true
GIGA_TIMEOUT=30

# Data
FLYFORECAST_DATASET_PATH=/app/data/processed/dataset_daily_flights.csv
PREDICTION_LOG_PATH=/app/data/interim/prediction_logs.jsonl

# Mendeleyevo / Kunashir approximate coordinates, можно потом уточнить
AIRPORT_LATITUDE=43.958
AIRPORT_LONGITUDE=145.683
AIRPORT_TIMEZONE=Asia/Sakhalin
